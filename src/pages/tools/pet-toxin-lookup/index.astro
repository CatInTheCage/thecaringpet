---
import Page from '../../../layouts/Page.astro';
import ToxinDisclaimer from '../../../components/ToxinDisclaimer.astro';
import PoisonHotlines from '../../../components/PoisonHotlines.astro';
import { toxins } from '../../../data/toxins';
import { SITE_URL, SITE_TITLE } from '../../../consts';
import type { Toxin, ToxinCategory, ToxinLevel } from '../../../types/toxin';

const title = 'Pet Toxin Lookup';
const description = 'Search common foods, plants, medications, and household items to check toxicity for dogs and cats. See severity, symptoms, and what to do.';
const image = '/images/hero.jpg';

const breadcrumbs = [
	{ label: 'Home', href: '/' },
	{ label: 'Tools', href: '/tools/' },
	{ label: 'Pet Toxin Lookup', href: '/tools/pet-toxin-lookup/' },
];

const categories: { slug: ToxinCategory | 'all'; label: string }[] = [
	{ slug: 'all', label: 'All' },
	{ slug: 'food', label: 'Foods' },
	{ slug: 'plant', label: 'Plants' },
	{ slug: 'medication', label: 'Medications' },
	{ slug: 'household', label: 'Household' },
	{ slug: 'insecticide', label: 'Insecticides' },
];

const levelLabel: Record<ToxinLevel, string> = {
	severe: 'Severe',
	moderate: 'Moderate',
	mild: 'Mild',
	safe: 'Safe',
};

// Slimmed list for the inline filter script (no first-aid / FAQ bloat in the DOM payload).
const toxinsIndex = toxins.map((t) => ({
	slug: t.slug,
	name: t.name,
	aliases: t.aliases,
	category: t.category,
	cat: { level: t.species.cat.level, toxic: t.species.cat.toxic },
	dog: { level: t.species.dog.level, toxic: t.species.dog.toxic },
}));

// Sort the rendered cards alphabetically for stable browsing.
const sortedToxins = [...toxins].sort((a, b) => a.name.localeCompare(b.name));

const searchTargetUrl = `${SITE_URL}/tools/pet-toxin-lookup/?q={search_term_string}`;

const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: `${SITE_TITLE} — Pet Toxin Lookup`,
	url: `${SITE_URL}/tools/pet-toxin-lookup/`,
	potentialAction: {
		'@type': 'SearchAction',
		target: {
			'@type': 'EntryPoint',
			urlTemplate: searchTargetUrl,
		},
		'query-input': 'required name=search_term_string',
	},
};

const itemListSchema = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	name: 'Pet Toxins Lookup Database',
	numberOfItems: toxins.length,
	itemListElement: toxins.map((t, i) => ({
		'@type': 'ListItem',
		position: i + 1,
		name: t.name,
		url: `${SITE_URL}/tools/pet-toxin-lookup/${t.slug}/`,
	})),
};
---

<Page title={title} description={description} image={image} breadcrumbs={breadcrumbs} wide={true}>
	<script type="application/ld+json" is:inline set:html={JSON.stringify(websiteSchema)} slot="head" />
	<script type="application/ld+json" is:inline set:html={JSON.stringify(itemListSchema)} slot="head" />

	<section class="tox-search-intro">
		<p class="lead text-muted">
			Type a food, plant, medication, or household item to see how toxic it is for dogs and cats,
			plus symptoms and what to do next. <strong>In an emergency, call a poison hotline right away.</strong>
		</p>
	</section>

	<section class="tox-search" aria-label="Toxin search">
		<div class="tox-search-box">
			<svg class="tox-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<circle cx="11" cy="11" r="8" />
				<line x1="21" y1="21" x2="16.65" y2="16.65" />
			</svg>
			<input
				type="search"
				id="tox-search-input"
				class="tox-search-input"
				placeholder="Search for a toxin, food, or plant… (e.g. soy sauce, chocolate, lily)"
				autocomplete="off"
				aria-label="Search toxins"
			/>
		</div>

		<div class="tox-filters">
			<div class="tox-filter-group" role="radiogroup" aria-label="Choose which species' toxicity to show on each card">
				<span class="tox-filter-label">Show labels for:</span>
				<label class="tox-pill">
					<input type="radio" name="species" value="all" checked />
					<span>All</span>
				</label>
				<label class="tox-pill">
					<input type="radio" name="species" value="cat" />
					<span>🐱 Cats</span>
				</label>
				<label class="tox-pill">
					<input type="radio" name="species" value="dog" />
					<span>🐕 Dogs</span>
				</label>
			</div>

			<div class="tox-filter-group" aria-label="Filter by category">
				<span class="tox-filter-label">Category:</span>
				{categories.map((cat) => (
					<label class="tox-pill">
						<input type="radio" name="category" value={cat.slug} checked={cat.slug === 'all'} />
						<span>{cat.label}</span>
					</label>
				))}
			</div>
		</div>
	</section>

	<p id="tox-result-count" class="tox-result-count" aria-live="polite" role="status"></p>

	<section id="tox-results" class="tox-results" aria-label="Toxin results">
		{sortedToxins.map((t) => (
			<a
				class="tox-result-card"
				href={`/tools/pet-toxin-lookup/${t.slug}/`}
				data-slug={t.slug}
				data-name={t.name.toLowerCase()}
				data-aliases={t.aliases.join(',').toLowerCase()}
				data-category={t.category}
				data-cat-level={t.species.cat.level}
				data-cat-toxic={String(t.species.cat.toxic)}
				data-dog-level={t.species.dog.level}
				data-dog-toxic={String(t.species.dog.toxic)}
			>
				<div class="tox-result-head">
					<h2 class="tox-result-name">{t.name}</h2>
					<span class="tox-result-cat">{t.category}</span>
				</div>
				<p class="tox-result-desc text-muted text-small">{t.description}</p>
				<div class="tox-result-badges">
					<span class={`tox-badge tox-badge--${t.species.cat.level}`} data-species-badge="cat">🐱 Cat: {levelLabel[t.species.cat.level]}</span>
					<span class={`tox-badge tox-badge--${t.species.dog.level}`} data-species-badge="dog">🐕 Dog: {levelLabel[t.species.dog.level]}</span>
				</div>
				<span class="tox-result-link">View details →</span>
			</a>
		))}

		<div id="tox-empty" class="tox-empty" hidden>
			<h2 id="tox-empty-title">No results found</h2>
			<p id="tox-empty-body">No toxins match your filters.</p>
			<div id="tox-empty-hotlines" hidden>
				<p class="tox-empty-note">
					<strong>Not finding something doesn't mean it's safe.</strong> This tool only lists
					substances already known to be toxic to cats or dogs. If your pet has eaten something
					and you're not sure whether it's dangerous, call a poison control hotline to confirm —
					don't rely on a missing search result.
				</p>
				<PoisonHotlines compact={true} />
			</div>
		</div>
	</section>

	<ToxinDisclaimer />

	{/* Hidden JSON payload for the inline filter script (kept slim on purpose). */}
	<script type="application/json" id="toxins-data" is:inline set:html={JSON.stringify(toxinsIndex)} />

	<script is:inline>
		(function () {
			const dataEl = document.getElementById('toxins-data');
			const cards = Array.from(document.querySelectorAll('.tox-result-card'));
			const input = document.getElementById('tox-search-input');
			const empty = document.getElementById('tox-empty');
			const emptyTitle = document.getElementById('tox-empty-title');
			const emptyBody = document.getElementById('tox-empty-body');
			const emptyHotlines = document.getElementById('tox-empty-hotlines');
			const countEl = document.getElementById('tox-result-count');
			const resultsGrid = document.getElementById('tox-results');

			const levelRank = { severe: 0, moderate: 1, mild: 2, safe: 3 };

			function currentSpecies() {
				const checked = document.querySelector('input[name="species"]:checked');
				return checked ? checked.value : 'all';
			}
			function currentCategory() {
				const checked = document.querySelector('input[name="category"]:checked');
				return checked ? checked.value : 'all';
			}

			function applyFilters() {
				const query = (input.value || '').trim().toLowerCase();
				const species = currentSpecies();
				const category = currentCategory();

				// The species toggle no longer hides cards — it controls which
				// toxicity labels (cat / dog / both) appear on each card. Only the
				// search query and category filter actually remove cards.
				document.querySelectorAll('[data-species-badge]').forEach((badge) => {
					const show = species === 'all' || badge.dataset.speciesBadge === species;
					badge.hidden = !show;
				});

				let visible = 0;
				cards.forEach((card) => {
					const name = card.dataset.name || '';
					const aliases = card.dataset.aliases || '';
					const matchesQuery =
						query === '' ||
						name.includes(query) ||
						aliases.split(',').some((a) => a.includes(query));
					const matchesCategory =
						category === 'all' || card.dataset.category === category;

					const show = matchesQuery && matchesCategory;
					card.hidden = !show;
					if (show) visible++;
				});

				empty.hidden = visible !== 0;
				countEl.textContent =
					visible === 0
						? 'No toxins match your search.'
						: `Showing ${visible} toxin${visible === 1 ? '' : 's'}.`;

				// Tailor the empty state: a typed query that matches nothing is very
				// different from a filter-only blank. The former needs the "not finding
				// it doesn't mean it's safe" note + hotlines; the latter does not.
				if (visible === 0) {
					if (query) {
						emptyTitle.textContent = `No entry for "${query}"`;
						emptyBody.textContent =
							'This tool only lists substances known to be toxic to cats or dogs.';
						emptyHotlines.hidden = false;
					} else {
						emptyTitle.textContent = 'No toxins match your filters';
						emptyBody.textContent =
							'Try a different species or category, or clear the search box.';
						emptyHotlines.hidden = true;
					}
				}

				// Update the shareable URL without reloading.
				if (query) {
					const url = new URL(window.location.href);
					url.searchParams.set('q', query);
					window.history.replaceState({}, '', url);
				} else {
					const url = new URL(window.location.href);
					url.searchParams.delete('q');
					window.history.replaceState({}, '', url);
				}
			}

			// Debounce typing so we don't thrash the DOM on every keystroke.
			let debounceTimer;
			input?.addEventListener('input', () => {
				clearTimeout(debounceTimer);
				debounceTimer = setTimeout(applyFilters, 120);
			});

			document.querySelectorAll('input[name="species"], input[name="category"]').forEach((el) => {
				el.addEventListener('change', applyFilters);
			});

			// Pre-fill from ?q= on load (shareable / SearchAction target).
			const params = new URLSearchParams(window.location.search);
			const initialQuery = params.get('q');
			if (initialQuery) {
				input.value = initialQuery;
			}
			applyFilters();
		})();
	</script>
</Page>

<style>
	.tox-search-intro {
		margin-bottom: var(--spacing-lg);
	}

	.tox-search-intro .lead {
		font-size: 1.1rem;
		line-height: 1.7;
		margin: 0;
	}

	.tox-search-box {
		position: relative;
		margin-bottom: var(--spacing-lg);
	}

	.tox-search-icon {
		position: absolute;
		left: var(--spacing-md);
		top: 50%;
		transform: translateY(-50%);
		width: 1.25rem;
		height: 1.25rem;
		color: hsl(var(--muted-foreground));
		pointer-events: none;
	}

	.tox-search-input {
		width: 100%;
		padding: var(--spacing-md) var(--spacing-md) var(--spacing-md) 3rem;
		font-size: 1.1rem;
		border: 1px solid hsl(var(--border));
		border-radius: var(--radius-md);
		background-color: hsl(var(--card));
		color: hsl(var(--foreground));
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
	}

	.tox-search-input:focus {
		outline: none;
		border-color: hsl(var(--primary));
		box-shadow: 0 0 0 3px hsl(var(--primary) / 0.15);
	}

	.tox-filters {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-md);
		margin-bottom: var(--spacing-lg);
	}

	.tox-filter-group {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--spacing-xs);
	}

	.tox-filter-label {
		font-size: 0.8rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: hsl(var(--muted-foreground));
		margin-right: var(--spacing-xs);
	}

	.tox-pill {
		display: inline-flex;
		align-items: center;
		border: 1px solid hsl(var(--border));
		border-radius: 9999px;
		padding: 0.35rem 0.85rem;
		font-size: 0.9rem;
		font-weight: 500;
		cursor: pointer;
		background-color: hsl(var(--card));
		color: hsl(var(--foreground));
		transition: all 0.2s ease;
	}

	.tox-pill:hover {
		border-color: hsl(var(--primary));
		background-color: hsl(var(--primary) / 0.05);
	}

	.tox-pill input[type="radio"] {
		position: absolute;
		opacity: 0;
		width: 0;
		height: 0;
	}

	.tox-pill:has(input:checked) {
		border-color: hsl(var(--primary));
		background-color: hsl(var(--primary));
		color: hsl(var(--primary-foreground));
		box-shadow: 0 0 0 1px hsl(var(--primary));
	}

	.tox-result-count {
		margin-bottom: var(--spacing-md);
		font-size: 0.9rem;
		color: hsl(var(--muted-foreground));
	}

	.tox-results {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--spacing-md);
	}

	@media (min-width: 560px) {
		.tox-results {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 900px) {
		.tox-results {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.tox-result-card {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-sm);
		padding: var(--spacing-lg);
		border: 1px solid hsl(var(--border));
		border-radius: var(--radius-card);
		background-color: hsl(var(--card));
		box-shadow: var(--shadow-card);
		text-decoration: none;
		transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
	}

	.tox-result-card:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-card-hover);
		border-color: hsl(var(--primary) / 0.3);
	}

	.tox-result-card:hover .tox-result-link {
		color: hsl(var(--primary-dark));
	}

	.tox-result-head {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: var(--spacing-sm);
	}

	.tox-result-name {
		font-size: 1.2rem;
		margin: 0;
		color: hsl(var(--foreground));
	}

	.tox-result-cat {
		font-size: 0.65rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: hsl(var(--muted-foreground));
		background-color: hsl(var(--muted));
		padding: 0.2rem 0.5rem;
		border-radius: 9999px;
		white-space: nowrap;
	}

	.tox-result-desc {
		flex: 1;
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.tox-result-badges {
		display: flex;
		gap: var(--spacing-xs);
		flex-wrap: wrap;
	}

	.tox-result-badges .tox-badge[hidden] {
		display: none;
	}

	.tox-result-link {
		font-weight: 600;
		color: hsl(var(--primary));
		transition: color 0.2s ease;
	}

	.tox-empty {
		grid-column: 1 / -1;
		text-align: center;
		padding: var(--spacing-2xl) var(--spacing-lg);
		border: 1px dashed hsl(var(--border));
		border-radius: var(--radius-card);
		background-color: hsl(var(--card));
	}

	.tox-empty h2 {
		margin-bottom: var(--spacing-sm);
	}

	.tox-empty p {
		color: hsl(var(--muted-foreground));
		margin-bottom: var(--spacing-lg);
	}

	.tox-empty-note {
		text-align: left;
		max-width: 540px;
		margin: 0 auto var(--spacing-lg);
		padding: var(--spacing-md) var(--spacing-lg);
		background-color: hsl(var(--primary) / 0.05);
		border-left: 3px solid hsl(var(--primary));
		border-radius: var(--radius-md);
		font-size: 0.95rem;
		line-height: 1.6;
		color: hsl(var(--foreground));
	}

	.tox-empty-note strong {
		color: hsl(var(--foreground));
	}

	.tox-result-card[hidden] {
		display: none;
	}
</style>
