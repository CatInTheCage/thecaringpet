---
import { NEWSLETTER_FORM_URL } from '../consts.ts';

interface Props {
	title?: string;
	description?: string;
	buttonText?: string;
	compact?: boolean;
	formUrl?: string;
}

const {
	title = "Get the Free Dog Feeding Safety Checklist",
	description = "Join our newsletter for research-backed feeding tips. Get the PDF guide instantly.",
	buttonText = "Get the Free Checklist",
	compact = false,
	formUrl,
} = Astro.props;

const actionUrl = formUrl ?? NEWSLETTER_FORM_URL;
---

<div class={`newsletter-box ${compact ? 'compact' : ''}`}>
	<div class="newsletter-content">
		{title && <h3>{title}</h3>}
		<p class="text-muted">{description}</p>
		<a
			href={actionUrl}
			target="_blank"
			rel="noopener noreferrer"
			class="btn btn-primary newsletter-cta"
		>
			{buttonText}
		</a>
	</div>
</div>

<style>
	.newsletter-box {
		background: linear-gradient(135deg, hsl(var(--primary) / 0.06) 0%, hsl(var(--secondary) / 0.06) 100%);
		border: 1px solid hsl(var(--border));
		border-radius: var(--radius-card);
		padding: var(--spacing-2xl);
	}

	.newsletter-box.compact {
		padding: 0;
		background: transparent;
		border: none;
	}

	.newsletter-content h3 {
		margin-bottom: var(--spacing-sm);
	}

	.newsletter-content p {
		margin-bottom: var(--spacing-md);
		font-size: 0.95rem;
	}

	.newsletter-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	@media (max-width: 768px) {
		.newsletter-cta {
			width: 100%;
		}
	}
</style>
