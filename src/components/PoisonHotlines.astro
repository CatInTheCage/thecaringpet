---
// ASPCA + Pet Poison Helpline call-to-action block.
// Reused on the toxin search page's empty state and every detail page's
// "When to Call the Vet" section so the numbers live in exactly one place
// (consts.ts). Numbers are verified periodically — see consts.ts lastVerified.
import { ASPCA_POISON_HOTLINE, PPH_POISON_HOTLINE } from '../consts';

interface Props {
	/** Heading above the two hotline cards. */
	title?: string;
	/** Compact rendering for inline use (search empty state). */
	compact?: boolean;
}
const { title = 'Poison Control Hotlines — Call Now', compact = false } = Astro.props;

const hotlines = [ASPCA_POISON_HOTLINE, PPH_POISON_HOTLINE];
---

<div class={`poison-hotlines${compact ? ' poison-hotlines--compact' : ''}`}>
	<p class="poison-hotlines-title">{title}</p>
	<div class="poison-hotlines-grid">
		{hotlines.map((h) => (
			<a class="poison-hotline-card" href={`tel:${h.tel}`} rel="noopener noreferrer">
				<span class="poison-hotline-name">{h.name}</span>
				<span class="poison-hotline-phone">{h.phone}</span>
				<span class="poison-hotline-note">Tap to call · 24/7 (consultation fee may apply)</span>
			</a>
		))}
	</div>
</div>
